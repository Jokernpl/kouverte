{
  "apps": [
    {
      "name": "vox",
      "script": "vox-server.js",
      "instances": 1,
      "exec_mode": "fork",
      "watch": false,
      "max_memory_restart": "500M",
      "env": {
        "NODE_ENV": "production",
        "PORT": 8082,
        "HOST": "0.0.0.0"
      },
      "error_file": "logs/vox-error.log",
      "out_file": "logs/vox-out.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss",
      "autorestart": true,
      "restart_delay": 5000,
      "max_restarts": 10
    }
  ]
}
