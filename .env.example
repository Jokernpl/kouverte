# ============= CONFIGURAZIONE KOUVERTE VOX PREMIUM =============

# Server
NODE_ENV=production
PORT=8082
HOST=0.0.0.0

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Database
DB_FILE=vox-data.json
DB_BACKUP=vox-data.bak.json

# Telegram Bot
BOT_TOKEN=your-telegram-bot-token
BOT_USERNAME=Kouverte_bot
WEBAPP_URL=https://www.kouverte.com/app.html

# Server API
SERVER_API=http://localhost:8082

# Bitcoin
BITCOIN_ADDRESS=bc1qssg5wplzn8a0euf8sp03uthwyuep48k7zw9c00
BITCOIN_MIN_CONFIRMATIONS=4

# Stripe (pagamenti con carta)
# Trovi le chiavi su https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
# Webhook secret: ottienilo da https://dashboard.stripe.com/webhooks
# dopo aver registrato l'endpoint https://www.kouverte.com/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Tunnel (per deployment)
TUNNEL_SERVICE=localhost.run  # o ngrok, localtunnel
TUNNEL_SUBDOMAIN=kouverte-vox

# CORS
ALLOWED_ORIGINS=*,https://www.kouverte.com,https://kouverte.com

# Features Toggle
FEATURE_LIVESTREAM=true
FEATURE_AI_MATCHING=true
FEATURE_MARKETPLACE=true
FEATURE_GAMIFICATION=true
FEATURE_WALLET=true

# Push Notifications
FCM_SERVER_KEY=your-firebase-cloud-messaging-key

# Rate Limiting
RATE_LIMIT_REGISTER=5/15min
RATE_LIMIT_LOGIN=10/15min
RATE_LIMIT_API=100/1hour

# Admin
ADMIN_EMAILS=admin@kouverte.com

# Logging
LOG_LEVEL=info
LOG_FILE=kouverte.log

# Cache
CACHE_TTL=3600
CACHE_MAX_SIZE=100MB
